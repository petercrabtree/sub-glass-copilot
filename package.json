{
	"name": "sub-glass-copilot",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"smoke:fixtures:refresh": "node scripts/refresh-smoke-fixture.mjs",
		"smoke:headless": "node scripts/headless-smoke.mjs",
		"smoke:headless:live": "node scripts/headless-smoke.mjs --reddit-source live",
		"smoke:headless:loop": "node scripts/headless-smoke.mjs --loop"
	},
	"devDependencies": {
		"@esbuild/win32-x64": "^0.28.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"puppeteer-core": "^24.40.0",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"idb": "^8.0.3"
	}
}
